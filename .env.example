# Copy to .env and edit. Copied as-is, the app runs with no backend:
# local-only storage, no auth, no accounts. That is a working starting point,
# not something to fix before you can build.
#
# Pick a backend when a slice actually needs one (accounts, sync, sharing).
# Uncomment ONE block below and fill it in; env-check then enforces the vars
# that provider requires and fails fast if any is missing.

EXPO_PUBLIC_BACKEND_PROVIDER=LOCAL_ONLY
EXPO_PUBLIC_AUTH_MODE=NONE

# --- Supabase ---
# Copy these from Project Settings -> API in your Supabase project.
# EXPO_PUBLIC_BACKEND_PROVIDER=SUPABASE
# EXPO_PUBLIC_AUTH_MODE=MAGIC_LINK
# EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Firebase ---
# EXPO_PUBLIC_BACKEND_PROVIDER=FIREBASE
# EXPO_PUBLIC_AUTH_MODE=EMAIL_PASSWORD
# EXPO_PUBLIC_FIREBASE_API_KEY=YOUR-API-KEY
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
# EXPO_PUBLIC_FIREBASE_APP_ID=YOUR-APP-ID
