# Supabase keys (FINDING-03 naming): the new CLI emits sb_publishable_... and sb_secret_...
#   - sb_publishable_...: modern publishable key, safe for the client. The current Supabase
#     local stack uses a shared default (not a secret).
#   - EXPO_PUBLIC_SUPABASE_ANON_KEY (below) is the template's LEGACY variable name. This does NOT imply
#     that "anon" and "publishable" are identical: the legacy field ACCEPTS your
#     modern publishable key (paste the sb_publishable_... value there).
#   - sb_secret_... / service_role: server only. Never put it in EXPO_PUBLIC_* or in the bundle.
EXPO_PUBLIC_BACKEND_PROVIDER=SUPABASE
EXPO_PUBLIC_AUTH_MODE=MAGIC_LINK
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
